# --- Database -----------------------------------------------------------------
POSTGRES_USER=pickem
POSTGRES_PASSWORD=pickem
POSTGRES_DB=pickem
DATABASE_URL=postgres://pickem:pickem@localhost:5432/pickem

# --- NATS ---------------------------------------------------------------------
NATS_URL=nats://localhost:4222

# --- Telegram bot -------------------------------------------------------------
# Obtain from @BotFather
TELEGRAM_BOT_TOKEN=
# Optional public webhook endpoint (leave empty to use long polling)
TELEGRAM_WEBHOOK_URL=

# --- Football data API --------------------------------------------------------
# https://www.football-data.org/
FOOTBALL_API_KEY=

# --- HTTP API service ---------------------------------------------------------
API_BIND_ADDR=0.0.0.0:8080

# --- OpenTelemetry / Jaeger ---------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=fut-worlds-pickem

# --- Logging ------------------------------------------------------------------
# Per-target overrides take the binary names: bot, api, events.
RUST_LOG=info,bot=debug,api=debug,events=debug
